# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_AGENT_NAME=ecommerce-assistant

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bedrock_legacy
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://redis:6379/0
SESSION_EXPIRY=3600

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# Service Ports
LEGACY_SYSTEM_PORT=8000
AGENT_RUNTIME_PORT=8001
MCP_GATEWAY_PORT=8002

# Service URLs
LEGACY_SYSTEM_URL=http://legacy-system:8000
MCP_GATEWAY_URL=http://mcp-gateway:8002

# OpenTelemetry
OTEL_ENABLED=True
OTEL_JAEGER_AGENT_HOST=jaeger
OTEL_JAEGER_AGENT_PORT=6831

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=30
AGENT_TEMPERATURE=0.7

# Environment
ENVIRONMENT=development
DEBUG=True
